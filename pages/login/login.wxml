<view class="container">
  <view class="hero">
    <image class="logo-img" src="/assets/icons/logo.svg" mode="aspectFit" />
    <text class="title">登录</text>
    <text class="welcome">欢迎回来!</text>
    <view class="register-line">
      <text class="register-tip">还没有账号? </text>
      <text class="register-link" bindtap="handleRegister">即刻注册</text>
    </view>
  </view>

  <view class="form-card">
    <text class="field-label">电话号码</text>
    <view class="field-row">
      <image class="field-icon" src="/assets/icons/手机号.svg" mode="aspectFit" />
      <input
        class="field-input"
        type="text"
        placeholder="+86 186 0323"
        placeholder-class="placeholder"
        value="{{phone}}"
        cursor="{{phoneCursor}}"
        bindinput="onPhoneInput"
        bindfocus="onPhoneFocus"
      />
    </view>

    <text class="field-label password-label">密码</text>
    <view class="field-row">
      <image class="field-icon" src="/assets/icons/登录密码.svg" mode="aspectFit" />
      <input
        class="field-input"
        password="{{!showPassword}}"
        placeholder=""
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
      <image
        class="eye-icon"
        src="/assets/icons/显示密码.svg"
        mode="aspectFit"
        bindtap="togglePassword"
      />
    </view>

    <text class="forgot" bindtap="handleForgotPassword">忘记密码了?</text>

    <button class="login-btn" loading="{{isLoggingIn}}" bindtap="handleAccountLogin">
      {{isLoggingIn ? "登录中..." : "登录"}}
    </button>

    <view wx:if="{{errorMsg}}" class="error-box">
      <text>{{errorMsg}}</text>
    </view>
  </view>

  <view class="third-party">
    <view class="line"></view>
    <text class="third-text">第三方登录</text>
    <view class="line"></view>
  </view>

  <view class="social-row">
    <view class="social-btn" bindtap="handleQQLogin">
      <image class="social-icon" src="/assets/icons/QQ(1).svg" mode="aspectFit" />
    </view>
    <view class="social-btn" bindtap="handleWechatLogin">
      <image class="social-icon" src="/assets/icons/微信(1).svg" mode="aspectFit" />
    </view>
  </view>
</view>
