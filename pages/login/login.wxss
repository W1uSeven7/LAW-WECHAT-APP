.container {
  min-height: 100vh;
  padding: 42rpx 42rpx 68rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.hero {
  margin-top: 68rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-img {
  width: 220rpx;
  height: 180rpx;
}

.title {
  display: block;
  margin-top: 18rpx;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 1rpx;
  color: #1d2a7a;
}

.welcome {
  margin-top: 52rpx;
  color: #98a6d1;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 1.35;
}

.register-line {
  margin-top: 12rpx;
  font-size: 38rpx;
  line-height: 1.4;
}

.register-tip {
  color: #9aa3d0;
}

.register-link {
  color: #ff9937;
}

.form-card {
  margin-top: 80rpx;
  padding: 44rpx 42rpx 48rpx;
  border: 2rpx solid #eef0ff;
  border-radius: 54rpx;
}

.field-label {
  display: block;
  color: #26306b;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.35;
}

.password-label {
  margin-top: 42rpx;
}

.field-row {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #edf0ff;
}

.field-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 18rpx;
}

.field-input {
  flex: 1;
  height: 64rpx;
  color: #26306b;
  font-size: 38rpx;
  line-height: 64rpx;
  font-weight: 500;
}

.placeholder {
  color: #2e3976;
  opacity: 0.72;
}

.eye-icon {
  width: 48rpx;
  height: 48rpx;
  margin-left: 16rpx;
}

.forgot {
  margin-top: 36rpx;
  display: inline-block;
  color: #ff9a39;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 500;
}

.login-btn {
  margin-top: 36rpx;
  width: calc(100% + 28rpx);
  margin-left: -14rpx;
  margin-right: -14rpx;
  box-sizing: border-box;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 24rpx;
  background: #ff9937;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  white-space: nowrap;
}

.login-btn::after {
  border: none;
}

.error-box {
  margin-top: 24rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: #fff2ef;
  color: #d84444;
  font-size: 24rpx;
  line-height: 1.5;
}

.third-party {
  margin-top: 82rpx;
  display: flex;
  align-items: center;
}

.line {
  flex: 1;
  height: 2rpx;
  background: #edf0ff;
}

.third-text {
  margin: 0 28rpx;
  color: #a1a9cf;
  font-size: 30rpx;
  line-height: 1.4;
  letter-spacing: 1rpx;
}

.social-row {
  margin-top: 34rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.social-btn {
  width: 118rpx;
  height: 118rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.social-icon {
  width: 118rpx;
  height: 118rpx;
  transform-origin: center center;
}
