.home-page {
  min-height: 100vh;
  padding: 32rpx 26rpx 180rpx;
  background: linear-gradient(180deg, #0b1220 0%, #111d31 100%);
  box-sizing: border-box;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.studio-name {
  display: block;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.studio-sub {
  display: block;
  margin-top: 8rpx;
  color: #9cb0cc;
  font-size: 24rpx;
}

.search-btn {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
}

.search-icon {
  font-size: 30rpx;
}

.banner-swiper {
  margin-top: 30rpx;
  height: 280rpx;
}

.banner-card {
  height: 100%;
  border-radius: 22rpx;
  padding: 30rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, rgba(41, 86, 149, 0.95) 0%, rgba(23, 47, 83, 0.95) 100%);
}

.banner-tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(62, 203, 255, 0.18);
  color: #84dcff;
  font-size: 22rpx;
}

.banner-title {
  display: block;
  margin-top: 24rpx;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}

.banner-desc {
  display: block;
  margin-top: 12rpx;
  color: #c9d7ea;
  font-size: 26rpx;
}

.section-title {
  margin-top: 34rpx;
  color: #d9e5f6;
  font-size: 30rpx;
  font-weight: 600;
}

.entry-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.entry-item {
  min-height: 178rpx;
  padding: 20rpx 16rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.07);
}

.entry-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #91e3ff;
  background: rgba(62, 203, 255, 0.14);
  font-size: 24rpx;
  font-weight: 700;
}

.entry-name {
  display: block;
  margin-top: 14rpx;
  color: #f5f9ff;
  font-size: 28rpx;
  font-weight: 600;
}

.entry-intro {
  display: block;
  margin-top: 6rpx;
  color: #93a6c3;
  font-size: 22rpx;
}

.shop-btn {
  margin-top: 34rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #ff7f50 0%, #ff5b47 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.ai-float {
  position: fixed;
  right: 26rpx;
  bottom: 180rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3ecbff 0%, #4478ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(16, 35, 71, 0.35);
}

.ai-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.logout {
  margin-top: 28rpx;
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #d8e3f2;
  font-size: 26rpx;
}

.logout::after {
  border: none;
}

.banner-swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.banner-swiper .wx-swiper-dot-active {
  width: 28rpx;
  border-radius: 999rpx;
}

.shop-btn::after {
  border: none;
}

.search-btn:active,
.entry-item:active,
.ai-float:active {
  opacity: 0.85;
}

.shop-btn:active {
  opacity: 0.92;
}

.section-tip {
  display: block;
  margin-top: 10rpx;
  color: #8ea2bf;
  font-size: 22rpx;
}
